{
    # Replace with your domain or use :80 for HTTP-only
    # yourdomain.com
}

:80 {
    # API gateway
    handle /auth/* {
        reverse_proxy gateway:8080
    }
    handle /api/* {
        reverse_proxy gateway:8080
    }
    handle /health {
        reverse_proxy gateway:8080
    }

    # Frontend (everything else)
    handle {
        reverse_proxy frontend:3000
    }
}
